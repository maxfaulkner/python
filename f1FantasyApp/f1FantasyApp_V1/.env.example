# Set these in Railway dashboard → your service → Variables

# Automatically set by Railway when you add the PostgreSQL plugin
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Server
PORT=3000
NODE_ENV=production

# Set these to your Railway service's public domain
# e.g. https://f1fantasy-production.up.railway.app
BASE_URL="https://your-app.up.railway.app"
FRONTEND_URL="https://your-app.up.railway.app"

# Copy from your local .env
JWT_SECRET="your-long-random-secret"

# Email (Gmail with app password)
EMAIL_SERVICE="gmail"
EMAIL_USER="your-gmail@gmail.com"
EMAIL_PASSWORD="your-app-specific-password"
EMAIL_FROM="your-gmail@gmail.com"
ADMIN_EMAIL="your-personal-email@gmail.com"
