clc; close all; clear all; 

data = readmatrix ('RotationalData.txt');

trimStart = 422;
trimEnd = 624;

timeData = data(422:,2);
rotationData = data(:,1);

timeData = (timeData)/10000;

for k = 2:length(timeData)
    deriv(k) = (rotationData(k) - rotationData(k-1)/(timeData(k) - timeData(k-1)));
end 

deriv


figure(1)
plot(timeData,rotationData)
xlabel('Time, s')
ylabel('Rotational Vel')
