import tkinter as tk

import irsdk
ir = irsdk.IRSDK()
ir.startup()

def update_variable(value):
    counter.set(value[1])

# Create a Tkinter root window
root = tk.Tk()
root.geometry("1000x1000") 

# Create a Tkinter variable to store the counter value
counter = tk.DoubleVar(value=0.0)

# Create a label widget to display the counter value in a big font
label = tk.Label(root, textvariable=counter, font=('Helvetica', 36), width=20, height=1)
label.pack(side = 'left', anchor='n')

# Create a thick outline around the label widget
label.config(bd=20, relief='solid')

# Continuously update the variable from an outside source
while True:
    # Example code to simulate an outside source updating the variable
    value = [round(ir['Speed'] * 2.23694, 2) , ir['RPM']]
    update_variable(value)
    root.update()

 